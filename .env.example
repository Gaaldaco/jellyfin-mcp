# Your Jellyfin server URL (no trailing slash)
JELLYFIN_URL=http://your-jellyfin-server:8096

# API key from Jellyfin Dashboard > Administration > API Keys
JELLYFIN_API_KEY=your-api-key-here

# Optional: Pin a specific user ID. If omitted, the first admin user is used automatically.
# JELLYFIN_USER_ID=

# Port for the MCP server (Railway sets this automatically)
PORT=3000
